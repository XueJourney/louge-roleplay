<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> - <%= appName %></title>
  <style>
    :root {
      --bg: #f5f4ed;
      --surface: #faf9f5;
      --surface-strong: #ffffff;
      --text: #141413;
      --text-secondary: #5e5d59;
      --text-tertiary: #87867f;
      --text-soft: #4d4c48;
      --text-emphasis: #3d3d3a;
      --border: #f0eee6;
      --border-strong: #e8e6dc;
      --ring: #d1cfc5;
      --ring-deep: #c2c0b6;
      --brand: #c96442;
      --brand-hover: #d97757;
      --dark: #30302e;
      --dark-deep: #141413;
      --dark-text: #b0aea5;
      --danger: #b53333;
      --shadow-soft: rgba(20, 20, 19, 0.05) 0px 4px 24px;
      --shadow-ring: 0px 0px 0px 1px var(--ring);
      --focus: #3898ec;
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --radius-xl: 24px;
      --radius-2xl: 32px;
    }

    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }
    a {
      color: var(--text-emphasis);
      text-decoration: none;
      transition: color 0.2s ease;
    }
    a:hover { color: var(--text); }
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px;
    }
    .nav {
      display: flex;
      gap: 16px;
      margin-bottom: 32px;
      align-items: center;
      flex-wrap: wrap;
      padding: 14px 18px;
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      background: rgba(250, 249, 245, 0.92);
      box-shadow: var(--shadow-soft);
      backdrop-filter: blur(8px);
    }
    .brand {
      font-family: Georgia, serif;
      font-weight: 500;
      font-size: 25px;
      line-height: 1.2;
      color: var(--text);
      margin-right: 8px;
    }
    .brand-url {
      color: var(--text-tertiary);
      font-size: 13px;
      margin-right: auto;
    }
    .nav a {
      font-size: 16px;
      color: var(--text-secondary);
    }
    .nav a:hover {
      color: var(--text);
    }
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 24px;
      margin-bottom: 16px;
      box-shadow: var(--shadow-soft);
    }
    h1, h2, h3, h4 {
      font-family: Georgia, serif;
      font-weight: 500;
      line-height: 1.15;
      margin: 0 0 12px;
      color: var(--text);
    }
    p { margin: 0 0 12px; }
    label {
      display: block;
      margin-bottom: 8px;
      font-size: 14px;
      line-height: 1.43;
      color: var(--text-soft);
    }
    input, textarea, select, button {
      width: 100%;
      box-sizing: border-box;
      margin-top: 0;
      margin-bottom: 0;
      padding: 12px 14px;
      border-radius: var(--radius-md);
      border: 1px solid var(--border-strong);
      background: var(--surface-strong);
      color: var(--text);
      font: inherit;
      transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, transform 0.2s ease;
    }
    input:focus, textarea:focus, select:focus {
      outline: none;
      border-color: var(--focus);
      box-shadow: 0 0 0 3px rgba(56, 152, 236, 0.12);
    }
    button {
      cursor: pointer;
      background: var(--dark);
      color: var(--surface);
      border: 1px solid var(--dark);
      box-shadow: 0px 0px 0px 1px var(--dark);
    }
    button:hover {
      transform: translateY(-1px);
      background: #3a3936;
    }
    code, pre {
      font-family: 'SFMono-Regular', Consolas, monospace;
      font-size: 14px;
      letter-spacing: -0.2px;
    }
    .row { display: flex; gap: 16px; }
    .row > * { flex: 1; }
    .muted { color: var(--text-secondary); font-size: 14px; }
    .message {
      padding: 14px 16px;
      border-radius: 16px;
      margin-bottom: 10px;
      white-space: pre-wrap;
    }

    @media (max-width: 768px) {
      .container { padding: 16px; }
      .nav {
        gap: 12px;
        margin-bottom: 20px;
        padding: 14px;
      }
      .brand-url {
        width: 100%;
        margin-right: 0;
        order: 3;
      }
      .card { padding: 18px; border-radius: 18px; }
      .row { flex-direction: column; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="nav">
      <a class="brand" href="/"><%= appName %></a>
      <span class="brand-url"><%= appUrl %></span>
      <a href="/">首页</a>
      <% if (currentUser) { %>
        <a href="/dashboard">控制台</a>
        <a href="/characters/new">创建角色</a>
        <a href="/logout">退出（<%= currentUser.username %>）</a>
      <% } else { %>
        <a href="/login">登录</a>
        <a href="/register">注册</a>
      <% } %>
    </div>
    <%- body %>
  </div>
</body>
</html>
